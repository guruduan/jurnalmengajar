<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/jurnalmengajar/db"
       VERSION="2026032500"
       COMMENT="Final production schema Jurnal Mengajar Sesudah diperbaiki"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">

<TABLES>

<!-- ========================= -->
<!-- JURNAL MENGAJAR -->
<!-- ========================= -->
<TABLE NAME="local_jurnalmengajar">
<FIELDS>
<FIELD NAME="id" TYPE="int" LENGTH="19" NOTNULL="true" SEQUENCE="true"/>
<FIELD NAME="userid" TYPE="int" LENGTH="19" NOTNULL="true"/>
<FIELD NAME="nomor" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
<FIELD NAME="kelas" TYPE="char" LENGTH="20" NOTNULL="true"/>
<FIELD NAME="jamke" TYPE="char" LENGTH="10"/>
<FIELD NAME="matapelajaran" TYPE="char" LENGTH="100" NOTNULL="true"/>
<FIELD NAME="materi" TYPE="text" NOTNULL="true"/>
<FIELD NAME="aktivitas" TYPE="text" NOTNULL="true"/>
<FIELD NAME="absen" TYPE="text"/>
<FIELD NAME="keterangan" TYPE="text"/>
<FIELD NAME="timecreated" TYPE="int" LENGTH="19" NOTNULL="true" DEFAULT="0"/>
</FIELDS>
<KEYS>
<KEY NAME="primary" TYPE="primary" FIELDS="id"/>
</KEYS>
<INDEXES>
<INDEX NAME="userid_idx" UNIQUE="false" FIELDS="userid"/>
</INDEXES>
</TABLE>

<!-- ========================= -->
<!-- BEBAN MENGAJAR -->
<!-- ========================= -->
<TABLE NAME="local_jurnalmengajar_beban">
<FIELDS>
<FIELD NAME="id" TYPE="int" LENGTH="19" NOTNULL="true" SEQUENCE="true"/>

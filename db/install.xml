<FIELD NAME="jam_perminggu" TYPE="int" LENGTH="11" NOTNULL="true"/>
</FIELDS>
<KEYS>
<KEY NAME="primary" TYPE="primary" FIELDS="id"/>
</KEYS>
</TABLE>


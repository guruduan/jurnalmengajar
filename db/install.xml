<FIELD NAME="hari" TYPE="char" LENGTH="20" NOTNULL="true"/>
<FIELD NAME="kelas" TYPE="char" LENGTH="20" NOTNULL="true"/>
<FIELD NAME="jamke" TYPE="int" LENGTH="2" NOTNULL="true"/>
<FIELD NAME="ruang" TYPE="char" LENGTH="20"/>
<FIELD NAME="timecreated" TYPE="int" LENGTH="19"/>
<FIELD NAME="timemodified" TYPE="int" LENGTH="19"/>
</FIELDS>
<KEYS>
<KEY NAME="primary" TYPE="primary" FIELDS="id"/>
</KEYS>
<INDEXES>
